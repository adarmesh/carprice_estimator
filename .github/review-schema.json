{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "security_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "description": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer" }
        },
        "required": ["severity", "description"]
      }
    },
    "error_handling_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "file": { "type": "string" },
          "suggestion": { "type": "string" }
        },
        "required": ["description"]
      }
    },
    "test_coverage": {
      "type": "object",
      "properties": {
        "assessment": { "type": "string", "enum": ["good", "adequate", "insufficient", "missing"] },
        "missing_cases": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["assessment"]
    },
    "summary": { "type": "string" }
  },
  "required": ["security_issues", "error_handling_gaps", "test_coverage", "summary"]
}
